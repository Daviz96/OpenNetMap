# Default: lascia decidere a Git in base al contenuto.
# (regola generica per prima: le successive, più specifiche, hanno precedenza)
* text=auto

# Normalizzazione line ending cross-platform.
# Gli script shell DEVONO restare LF, altrimenti si rompono su Linux/macOS
# (errore "bad interpreter"). Gli script PowerShell restano CRLF su Windows.
*.sh   text eol=lf
*.ps1  text eol=crlf

# Librerie JS vendorizzate: trattale come binarie per non alterarne i byte/EOL.
network_inventory/static/*.js binary
